# Supabase (obtener en: Project Settings > API del proyecto Supabase que quieras usar)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
# Solo servidor; necesario para booking público y operaciones admin
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# App URLs (producción: tu dominio Vercel, ej. https://tu-app.vercel.app)
NEXT_PUBLIC_SITE_URL=https://tu-app.vercel.app
NEXT_PUBLIC_APP_URL=https://tu-app.vercel.app

# Email (Resend) - opcional; sin esto los emails de contacto/citas no se envían
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=EstéticaApp <noreply@tudominio.com>
